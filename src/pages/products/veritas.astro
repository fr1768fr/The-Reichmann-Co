---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import { SITE } from '../../data/site';

const description = 'Veritas. An AI built for South African accountants. Accuracy-first, with deep understanding of SA tax law and accounting practice. Currently in research.';

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Veritas',
  applicationCategory: 'BusinessApplication',
  applicationSubCategory: 'Artificial Intelligence',
  operatingSystem: 'Web',
  url: `${SITE.url}/products/veritas`,
  description: 'Veritas is an AI built for South African accountants, focused on accuracy and deep understanding of SA tax law and accounting practice. Currently in research at The Reichmann Co.',
  publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/PreOrder',
    url: `${SITE.url}/products/veritas`,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Products', item: `${SITE.url}/products` },
    { '@type': 'ListItem', position: 3, name: 'Veritas', item: `${SITE.url}/products/veritas` },
  ],
};

const tags = ['AI', 'SA Tax', 'IFRS for SMEs', 'Compliance', 'Audit', 'Reconciliation', 'Retrieval-Augmented', 'Verifiable'];
---

<BaseLayout
  title="Veritas · The Reichmann Co."
  description={description}
  ogImage={`${SITE.url}/og/veritas.png`}
  ogImageAlt="Veritas, an AI built for South African accountants"
  jsonLd={[productSchema, breadcrumbSchema]}
  activeNav="products"
>
  <section class="page-hero">
    <div class="container container-wide">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/products">Products</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Veritas</span>
      </nav>

      <div class="veritas-hero">
        <div class="veritas-hero-meta">
          <span class="status">
            <span class="status-dot"></span> In Research
          </span>
          <span class="product-category">Accounting Intelligence</span>
        </div>
        <h1 class="veritas-name">Veritas</h1>
        <p class="veritas-tagline">Truth, for accountants.</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container container-prose veritas-intro">
      <p class="lead">
        Veritas is an AI built for South African accountants. Accuracy-first,
        grounded in SA tax law and accounting practice, designed for the work
        that actually fills an accountant&rsquo;s week: reconciliations, compliance
        checks, tax queries, audit trails, and explanation of the law behind
        each answer.
      </p>
      <p>
        It is a standalone product today, in active research at The Reichmann
        Co. Over time it becomes the intelligence layer inside Lumarix as well,
        so accountants who eventually use both get the same answers in either
        place.
      </p>

      <aside class="why-name">
        <span class="eyebrow">Why &ldquo;Veritas&rdquo;</span>
        <p>
          The name comes from the Latin <em>veritas</em>, meaning truth. We picked
          it deliberately. Accountants spend their careers verifying that the
          numbers reflect reality. An AI that hallucinates is worse than no AI at
          all for that audience, so Veritas is being built around verifiability:
          every answer cites the legislation, the standard, or the source data it
          came from. If it cannot back its claim, it says so.
        </p>
      </aside>

      <ul class="product-tags">
        {tags.map((t) => <li>{t}</li>)}
      </ul>
    </div>
  </section>

  <section class="section section--inverse closing-cta">
    <div class="container container-wide closing-inner">
      <span class="eyebrow eyebrow--on-dark">Stay close to the work</span>
      <h2 class="closing-title">Veritas is in research.</h2>
      <p class="closing-sub">When early access opens, we will reach out to the accountants on our list first.</p>
      <div class="closing-cta-row">
        <Button href="/contact" variant="inverse" size="lg" arrow>Get in touch</Button>
        <Button href="/products/lumarix" variant="ghost" size="lg" class="closing-ghost">See Lumarix</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .veritas-hero { max-width: 56rem; }

  .veritas-hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    align-items: center;
    margin-bottom: var(--space-6);
  }

  .veritas-name {
    font-size: clamp(3.5rem, 7vw, 5.5rem);
    font-weight: var(--fw-bold);
    letter-spacing: -0.04em;
    line-height: 1;
    background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-700) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .veritas-tagline {
    margin-top: var(--space-4);
    font-size: var(--fs-2xl);
    color: var(--text-secondary);
    line-height: var(--lh-snug);
    font-style: italic;
  }

  .status {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    font-size: var(--fs-xs);
    font-family: var(--font-mono);
    font-weight: var(--fw-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    background: var(--brand-tint);
    color: var(--brand-primary);
    border: 1px solid var(--brand-tint-strong);
  }
  .status-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: currentColor;
    box-shadow: 0 0 0 3px color-mix(in srgb, currentColor 30%, transparent);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  .product-category {
    font-size: var(--fs-xs);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--text-muted);
  }

  .veritas-intro .lead {
    color: var(--text-primary);
    font-size: var(--fs-xl);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-5);
  }
  .veritas-intro p {
    color: var(--text-secondary);
    font-size: var(--fs-lg);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-5);
  }

  .why-name {
    margin-top: var(--space-8);
    padding: var(--space-6) var(--space-8);
    background: var(--bg-subtle);
    border-left: 3px solid var(--brand-primary);
    border-radius: var(--radius-md);
  }
  .why-name p {
    margin-top: var(--space-3);
    color: var(--text-secondary);
    line-height: var(--lh-relaxed);
  }
  .why-name em { color: var(--brand-primary); font-style: italic; }

  .product-tags {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-10);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-subtle);
  }
  .product-tags li {
    padding: var(--space-1) var(--space-3);
    background: var(--brand-tint);
    color: var(--brand-primary);
    font-size: var(--fs-xs);
    font-family: var(--font-mono);
    border-radius: var(--radius-pill);
  }
</style>

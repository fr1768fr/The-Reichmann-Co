---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import { SITE } from '../../data/site';

const description = 'Mobile app development by The Reichmann Co. Native iOS and Android applications, from MVP to App Store launch.';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'Mobile App Development',
  name: 'Mobile Apps',
  url: `${SITE.url}/services/mobile-apps`,
  provider: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  areaServed: { '@type': 'Country', name: 'South Africa' },
  description: 'Native iOS and Android applications, polished, performant, and built to scale from MVP to App Store launch.',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE.url}/services` },
    { '@type': 'ListItem', position: 3, name: 'Mobile Apps', item: `${SITE.url}/services/mobile-apps` },
  ],
};
---

<BaseLayout
  title="Mobile Apps · The Reichmann Co."
  description={description}
  jsonLd={[serviceSchema, breadcrumbSchema]}
  activeNav="services"
>
  <section class="page-hero">
    <div class="container container-wide">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/services">Services</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">Mobile Apps</span>
      </nav>
      <span class="eyebrow">Service</span>
      <h1 class="page-hero-title">Mobile Apps.</h1>
      <p class="page-hero-sub">
        Native iOS and Android applications, polished, performant, and built
        to scale from MVP to App Store launch and beyond.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container container-wide">
      <div class="info-grid">
        <div class="info-card">
          <h3>What is included</h3>
          <ul class="feature-list">
            <li>Native iOS (Swift) and Android (Kotlin) builds</li>
            <li>App Store and Play Store submission</li>
            <li>Push notifications, offline support, deep linking</li>
            <li>In-app purchases and subscriptions</li>
            <li>Crash reporting and analytics</li>
          </ul>
        </div>
        <div class="info-card">
          <h3>When to choose this</h3>
          <p class="info-card-prose">
            When performance, platform integration, or App Store presence
            matters. For most product MVPs, a responsive web app or PWA is
            faster to launch. We will tell you honestly which fits your use case.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--inverse closing-cta">
    <div class="container container-wide closing-inner">
      <span class="eyebrow eyebrow--on-dark">App in mind</span>
      <h2 class="closing-title">Tell us about your app idea.</h2>
      <div class="closing-cta-row">
        <Button href="/contact" variant="inverse" size="lg" arrow>Start a project</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .info-card-prose { color: var(--text-secondary); line-height: var(--lh-relaxed); }
</style>

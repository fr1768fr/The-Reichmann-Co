---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import { SITE } from '../../data/site';

const description = 'SaaS product development by The Reichmann Co. End-to-end design and engineering: auth, billing, infrastructure, and the product itself.';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'SaaS Product Development',
  name: 'SaaS Products',
  url: `${SITE.url}/services/saas-products.html`,
  provider: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  areaServed: 'Worldwide',
  description: 'End-to-end SaaS development from blank canvas to paying customers, including authentication, billing, and infrastructure.',
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE.url}/services.html` },
    { '@type': 'ListItem', position: 3, name: 'SaaS Products', item: `${SITE.url}/services/saas-products.html` },
  ],
};
---

<BaseLayout
  title="SaaS Products · The Reichmann Co."
  description={description}
  jsonLd={[serviceSchema, breadcrumbSchema]}
  activeNav="services"
>
  <section class="page-hero">
    <div class="container container-wide">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span aria-hidden="true">/</span>
        <a href="/services.html">Services</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">SaaS Products</span>
      </nav>
      <span class="eyebrow">Service</span>
      <h1 class="page-hero-title">SaaS Products.</h1>
      <p class="page-hero-sub">
        End to end SaaS development. We design, build, and ship subscription
        products, from blank canvas to paying customers.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container container-wide">
      <div class="info-grid">
        <div class="info-card">
          <h3>What is included</h3>
          <ul class="feature-list">
            <li>Product discovery and roadmap</li>
            <li>UX, UI, and design system</li>
            <li>Authentication and authorisation</li>
            <li>Billing and subscription management (Stripe, Paddle)</li>
            <li>Multi-tenant architecture and data isolation</li>
            <li>Admin tooling, observability, and analytics</li>
            <li>Production deployment and ongoing support</li>
          </ul>
        </div>
        <div class="info-card">
          <h3>Typical stack</h3>
          <ul class="feature-list">
            <li>TypeScript with Next.js or SvelteKit</li>
            <li>Postgres (Supabase or Neon) for primary data</li>
            <li>Stripe for billing</li>
            <li>Resend or Postmark for transactional email</li>
            <li>Vercel or Fly.io for hosting</li>
            <li>Sentry and Plausible for observability</li>
          </ul>
        </div>
      </div>

      <aside class="service-callout">
        <h3>We use what we build.</h3>
        <p>
          <a href="/products/lumarix.html">Lumarix</a>, our own ERP for accountants,
          is built on the same stack and approach we bring to client work.
        </p>
      </aside>
    </div>
  </section>

  <section class="section section--inverse closing-cta">
    <div class="container container-wide closing-inner">
      <span class="eyebrow eyebrow--on-dark">Building a SaaS</span>
      <h2 class="closing-title">Tell us what you are building.</h2>
      <p class="closing-sub">From sketch on a napkin to paying customers, we cover it.</p>
      <div class="closing-cta-row">
        <Button href="/contact.html" variant="inverse" size="lg" arrow>Start a project</Button>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .service-callout {
    margin-top: var(--space-8);
    padding: var(--space-6) var(--space-8);
    background: var(--brand-tint);
    border: 1px solid var(--brand-tint-strong);
    border-radius: var(--radius-lg);
  }
  .service-callout h3 {
    font-size: var(--fs-lg);
    margin-bottom: var(--space-2);
    color: var(--brand-deep);
  }
  .service-callout p {
    color: var(--text-secondary);
    line-height: var(--lh-relaxed);
  }
  .service-callout a {
    color: var(--brand-primary);
    font-weight: var(--fw-semibold);
  }
  :global([data-theme='dark']) .service-callout h3 { color: var(--brand-200); }
</style>

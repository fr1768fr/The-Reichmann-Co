---
import { SITE } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container container-wide footer-grid">
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label={`${SITE.name} home`}>
        <img src="/favicon-light-192.png" alt="" width="36" height="36" />
        <span>{SITE.name}</span>
      </a>
      <p class="footer-tagline">{SITE.shortTagline}</p>
      <div class="footer-social">
        <a
          href={SITE.linkedin}
          target="_blank"
          rel="noopener"
          aria-label={`${SITE.name} on LinkedIn`}
          class="footer-social-link"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"></path>
          </svg>
        </a>
        <a
          href={SITE.facebook}
          target="_blank"
          rel="noopener"
          aria-label={`${SITE.name} on Facebook`}
          class="footer-social-link"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-3 7h-1.924c-.615 0-1.076.252-1.076.889v1.111h3l-.238 3h-2.762v8h-3v-8h-2v-3h2v-1.923c0-2.022 1.064-3.077 3.461-3.077h2.539v3z"></path>
          </svg>
        </a>
        <a
          href={SITE.instagram}
          target="_blank"
          rel="noopener"
          aria-label={`${SITE.name} on Instagram`}
          class="footer-social-link"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"></path>
          </svg>
        </a>
      </div>
    </div>

    <div class="footer-col">
      <h5 class="footer-heading">Company</h5>
      <ul>
        <li><a href="/about">About</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="/products">Products</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h5 class="footer-heading">Solutions</h5>
      <ul>
        <li><a href="/services/web-applications">Web Applications</a></li>
        <li><a href="/services/saas-products">SaaS Products</a></li>
        <li><a href="/services/mobile-apps">Mobile Apps</a></li>
        <li><a href="/services/cloud-backend">Cloud &amp; Backend</a></li>
        <li><a href="/services/ai-integrations">AI &amp; Integrations</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h5 class="footer-heading">Products</h5>
      <ul>
        <li><a href="/products/lumarix">Lumarix</a></li>
        <li><a href="/downloads/lumarix">Download Lumarix</a></li>
        <li><a href="/founding-testers">Founding Testers</a></li>
        <li><a href="/products/veritis">Veritis</a></li>
      </ul>
    </div>

    <div class="footer-col">
      <h5 class="footer-heading">Legal</h5>
      <ul>
        <li><a href="/privacy">Privacy Policy</a></li>
        <li class="footer-meta">{SITE.legalName}</li>
        <li class="footer-meta">Reg. No. {SITE.registration}</li>
      </ul>
    </div>
  </div>

  <div class="container container-wide footer-bottom">
    <p>&copy; {year} {SITE.legalName}. All rights reserved.</p>
    <p class="footer-meta">Based in {SITE.country}</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-24);
    padding-block: var(--space-20) var(--space-8);
    background: var(--bg-subtle);
    border-top: 1px solid var(--border-subtle);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr repeat(4, 1fr);
    gap: var(--space-12) var(--space-8);
  }

  .footer-brand {
    max-width: 22rem;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-primary);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-4);
  }

  .footer-logo img {
    border-radius: var(--radius-sm);
  }

  .footer-tagline {
    color: var(--text-muted);
    font-size: var(--fs-sm);
    line-height: var(--lh-relaxed);
    margin-bottom: var(--space-5);
  }

  .footer-social { display: flex; gap: var(--space-2); }

  .footer-social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: var(--radius-md);
    color: var(--text-muted);
    border: 1px solid var(--border-subtle);
    transition: color var(--duration-fast) var(--ease-out),
                border-color var(--duration-fast) var(--ease-out),
                background-color var(--duration-fast) var(--ease-out);
  }

  .footer-social-link:hover {
    color: var(--brand-primary);
    border-color: var(--brand-primary);
    background: var(--brand-tint);
  }

  .footer-col ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-heading {
    font-size: var(--fs-xs);
    font-family: var(--font-mono);
    font-weight: var(--fw-medium);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--text-muted);
    margin-bottom: var(--space-5);
  }

  .footer-col a {
    color: var(--text-secondary);
    font-size: var(--fs-sm);
    transition: color var(--duration-fast) var(--ease-out);
  }

  .footer-col a:hover { color: var(--brand-primary); }

  .footer-meta {
    color: var(--text-subtle);
    font-size: var(--fs-xs);
    font-family: var(--font-mono);
  }

  .footer-bottom {
    margin-top: var(--space-16);
    padding-top: var(--space-6);
    border-top: 1px solid var(--border-subtle);
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: var(--space-3);
    color: var(--text-muted);
    font-size: var(--fs-xs);
  }

  @media (max-width: 960px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer-brand { grid-column: 1 / -1; max-width: none; }
  }

  @media (max-width: 480px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>

# Copy to .env and fill in for local dev. .env is gitignored. On Vercel, set these as
# Environment Variables in the project settings instead.

# --- Email: Lumarix early-access form (src/pages/api/beta-signup.ts) ---
RESEND_API_KEY=
NOTIFICATION_EMAIL=info@thereichmannco.co.za
RESEND_FROM=Lumarix Early Access <onboarding@resend.dev>

# --- Lumarix licensing backend (src/pages/api/license/*) ---
# Vendor ECDSA P-256 private key that signs entitlement tokens. Generate with:
#   node scripts/license-keygen.mjs
# Paste the PKCS#8 PEM here (raw, with escaped \n, or base64-encoded — all accepted). SECRET.
LICENSE_PRIVATE_KEY=
# Bearer token guarding the admin API (/api/license/admin). Use a long random string.
LICENSE_ADMIN_TOKEN=
# Upstash Redis (add via Vercel Marketplace → Storage). Injected automatically on Vercel;
# set locally only for dev against a real KV (otherwise a local JSON file is used).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
